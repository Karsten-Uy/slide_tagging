# Copy this file to `.env` and fill in your key:  cp .env.example .env
# `.env` is gitignored, so your real key is never committed.
# Loaded automatically by `slide-tagger` (e.g. the `bench` command).

# Anthropic API key — required for `slide-tagger bench` (the automated, API-driven
# enrichment benchmark). Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional: path to poppler's bin/ so `slide-tagger render` can rasterize PDFs
# without poppler on your system PATH. (render also needs LibreOffice for .pptx.)
# A portable poppler was unpacked here during setup:
# POPPLER_PATH=C:\Users\karst\poppler\poppler-26.02.0\Library\bin
